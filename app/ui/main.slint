// Minimal dark pill button: TouchArea-backed (a plain Rectangle has no `has-hover`),
// reused by the bottom toolbar and the edge-navigation glyphs. `enabled` is forwarded
// to the inner TouchArea so a hidden (faded-out) button passes clicks through to the
// image's view controls underneath instead of swallowing them.
component ToolButton inherits Rectangle {
    in property <string> label;
    in property <length> font-size: 14px;
    in property <bool> enabled: true;
    out property <bool> has-hover: touch.has-hover;
    callback clicked;

    background: touch.has-hover ? #ffffff30 : #ffffff14;
    border-radius: 4px;
    horizontal-stretch: 0;
    min-width: t.preferred-width + 16px;
    min-height: t.preferred-height + 10px;

    t := Text {
        text: root.label;
        color: white;
        font-size: root.font-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component AppWindow inherits Window {
    title: "Photo Viewer";
    background: black;
    preferred-width: 1024px;
    preferred-height: 768px;

    in property <image> current-image;
    in property <string> caption: "";
    in property <string> status-text: "";

    // Explicit image geometry, driven by the app from ViewState::geometry().
    in property <length> disp-x;
    in property <length> disp-y;
    in property <length> disp-w;
    in property <length> disp-h;
    in property <bool> smooth: true;
    in property <float> zoom-percent;

    // Info overlay (I key). `info-visible` is in-out so Esc can clear it from Slint too.
    in-out property <bool> info-visible;
    in property <string> info-name;
    in property <string> info-path;
    in property <string> info-dims;          // e.g. "1920 × 1080"
    in property <string> info-size;          // e.g. "2.3 MB"
    in property <int> rotation-degrees;

    // Keyboard view-control steps. `zoom-step` mirrors viewstate::ZOOM_STEP (the Rust
    // const can't be imported into Slint); `pan-step` is the Shift+arrow nudge distance.
    property <float> zoom-step: 1.25;
    property <length> pan-step: 80px;

    // Last pointer position captured on press, so `moved` can pan by the delta.
    property <length> pan-anchor-x;
    property <length> pan-anchor-y;

    callback quit();
    callback next-image();
    callback prev-image();

    callback viewport-changed(length, length);     // (w, h)
    callback zoom-by(float, length, length);        // (factor, anchor-x, anchor-y)
    callback pan-by(length, length);                // (dx, dy)
    callback rotate-cw();
    callback rotate-ccw();
    callback cycle-view();
    callback toggle-fullscreen();
    callback toggle-info();
    // nat-w, nat-h = displayed (post-rotation) pixel dims; is-new-image = Show (reset Fit) vs rotate (keep mode)
    callback image-presented(int, int, bool);

    forward-focus: keys;

    viewport := Rectangle {
        clip: true;
        width: 100%;
        height: 100%;
        changed width => {
            root.viewport-changed(self.width, self.height);
        }
        changed height => {
            root.viewport-changed(self.width, self.height);
        }
        Image {
            x: root.disp-x;
            y: root.disp-y;
            width: root.disp-w;
            height: root.disp-h;
            source: root.current-image;
            image-rendering: root.smooth ? ImageRendering.smooth : ImageRendering.pixelated;
        }

        // Mouse view controls. Fills the viewport so `mouse-x`/`mouse-y` are in the same
        // viewport-relative coordinates the zoom/pan callbacks expect. Scroll zooms toward
        // the cursor; left-drag pans by the pointer delta. Geometry clamping lives in
        // ViewState (unit-tested), so the behaviour is verified manually.
        ta := TouchArea {
            scroll-event(e) => {
                root.zoom-by(e.delta-y > 0 ? root.zoom-step : 1.0 / root.zoom-step, self.mouse-x, self.mouse-y);
                return EventResult.accept;
            }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    root.pan-anchor-x = self.mouse-x;
                    root.pan-anchor-y = self.mouse-y;
                }
            }
            moved => {
                root.pan-by(self.mouse-x - root.pan-anchor-x, self.mouse-y - root.pan-anchor-y);
                root.pan-anchor-x = self.mouse-x;
                root.pan-anchor-y = self.mouse-y;
            }
        }
    }

    Text {
        width: 100%;
        height: 100%;
        text: root.status-text;
        visible: root.status-text != "";
        color: white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    Text {
        x: 8px;
        y: 8px;
        text: root.caption;
        color: white;
        visible: root.caption != "";
    }

    // Info overlay, top-left and offset below the caption so the two don't collide.
    // Sits above the image/viewport in z-order; can sit below a future toolbar (Task 9).
    info-panel := Rectangle {
        x: 8px;
        y: 32px;
        visible: root.info-visible;
        background: #000000cc;
        border-radius: 6px;
        width: info-layout.preferred-width;
        height: info-layout.preferred-height;

        info-layout := VerticalLayout {
            padding: 10px;
            spacing: 4px;

            Text {
                text: "Name: " + root.info-name;
                color: white;
            }
            Text {
                text: "Path: " + root.info-path;
                color: white;
            }
            Text {
                text: "Dimensions: " + root.info-dims;
                color: white;
            }
            Text {
                text: "File size: " + root.info-size;
                color: white;
            }
            Text {
                text: "Zoom: \{root.zoom-percent}%";
                color: white;
            }
            Text {
                text: "Rotation: \{root.rotation-degrees}°";
                color: white;
            }
            // Rating/tags intentionally omitted — they arrive with the metadata plan (Plan 3).
        }
    }

    // --- Auto-hiding chrome (Task 9) -------------------------------------------------
    // Event-driven proximity reveal (no timers/polling, per AGENTS.md): the bottom
    // toolbar and the left/right edge glyphs fade in while the pointer (`ta` covers the
    // whole viewport) is near the relevant edge, and stay visible while hovered. When
    // hidden the interactive TouchAreas are `enabled: false` so they pass clicks/drags
    // through to the image's view controls underneath.
    property <bool> toolbar-shown: (ta.has-hover && ta.mouse-y > viewport.height - 80px) || toolbar-cover.has-hover;
    property <bool> left-edge-shown: (ta.has-hover && ta.mouse-x < 80px) || left-edge.has-hover;
    property <bool> right-edge-shown: (ta.has-hover && ta.mouse-x > viewport.width - 80px) || right-edge.has-hover;

    toolbar := Rectangle {
        x: (parent.width - layout.preferred-width) / 2;
        y: parent.height - self.height - 8px;
        width: layout.preferred-width;
        height: layout.preferred-height;
        background: #000000cc;
        border-radius: 8px;
        opacity: root.toolbar-shown ? 1.0 : 0.0;
        animate opacity { duration: 150ms; }

        // Under the buttons (declared first → painted below, so buttons win clicks).
        // Provides the toolbar's own `has-hover` to keep the bar visible while the
        // pointer rests in the padding/gaps between buttons.
        toolbar-cover := TouchArea {
            enabled: root.toolbar-shown;
        }

        layout := HorizontalLayout {
            padding: 6px;
            spacing: 6px;
            ToolButton {
                label: "◀ Prev";
                enabled: root.toolbar-shown;
                clicked => {
                    root.prev-image();
                }
            }
            ToolButton {
                label: "Next ▶";
                enabled: root.toolbar-shown;
                clicked => {
                    root.next-image();
                }
            }
            ToolButton {
                label: "↺ Rotate L";
                enabled: root.toolbar-shown;
                clicked => {
                    root.rotate-ccw();
                }
            }
            ToolButton {
                label: "Rotate R ↻";
                enabled: root.toolbar-shown;
                clicked => {
                    root.rotate-cw();
                }
            }
            ToolButton {
                label: "⤢ Fullscreen";
                enabled: root.toolbar-shown;
                clicked => {
                    root.toggle-fullscreen();
                }
            }
            ToolButton {
                label: "✕ Exit";
                enabled: root.toolbar-shown;
                clicked => {
                    root.quit();
                }
            }
        }
    }

    left-edge := ToolButton {
        x: 8px;
        y: (parent.height - self.height) / 2;
        label: "‹";
        font-size: 48px;
        enabled: root.left-edge-shown;
        opacity: root.left-edge-shown ? 1.0 : 0.0;
        animate opacity { duration: 150ms; }
        clicked => {
            root.prev-image();
        }
    }

    right-edge := ToolButton {
        x: parent.width - self.width - 8px;
        y: (parent.height - self.height) / 2;
        label: "›";
        font-size: 48px;
        enabled: root.right-edge-shown;
        opacity: root.right-edge-shown ? 1.0 : 0.0;
        animate opacity { duration: 150ms; }
        clicked => {
            root.next-image();
        }
    }

    keys := FocusScope {
        // Pan convention: a Shift+arrow nudges the image in the direction the arrow
        // points (Shift+Left moves the image right, i.e. reveals its left edge);
        // ViewState clamps so over-panning is harmless.
        key-pressed(event) => {
            // Q always quits. Esc closes the info overlay if it's open, otherwise quits.
            if (event.text == "q" || event.text == "Q") {
                root.quit();
                return EventResult.accept;
            }
            if (event.text == Key.Escape) {
                if (root.info-visible) {
                    root.info-visible = false;
                } else {
                    root.quit();
                }
                return EventResult.accept;
            }
            if (event.modifiers.shift) {
                // Pan: arrows or H/J/K/L (Shift uppercases the letter).
                if (event.text == Key.LeftArrow || event.text == "H") {
                    root.pan-by(root.pan-step, 0);
                    return EventResult.accept;
                }
                if (event.text == Key.RightArrow || event.text == "L") {
                    root.pan-by(-root.pan-step, 0);
                    return EventResult.accept;
                }
                if (event.text == Key.UpArrow || event.text == "K") {
                    root.pan-by(0, root.pan-step);
                    return EventResult.accept;
                }
                if (event.text == Key.DownArrow || event.text == "J") {
                    root.pan-by(0, -root.pan-step);
                    return EventResult.accept;
                }
                return EventResult.reject;
            }
            if (event.text == Key.UpArrow || event.text == "k" || event.text == "K") {
                root.zoom-by(root.zoom-step, viewport.width / 2, viewport.height / 2);
                return EventResult.accept;
            }
            if (event.text == Key.DownArrow || event.text == "j" || event.text == "J") {
                root.zoom-by(1.0 / root.zoom-step, viewport.width / 2, viewport.height / 2);
                return EventResult.accept;
            }
            if (event.text == Key.RightArrow || event.text == "l" || event.text == "L") {
                root.next-image();
                return EventResult.accept;
            }
            if (event.text == Key.LeftArrow || event.text == "h" || event.text == "H") {
                root.prev-image();
                return EventResult.accept;
            }
            if (event.text == "e" || event.text == "E") {
                root.rotate-ccw();
                return EventResult.accept;
            }
            if (event.text == "r" || event.text == "R") {
                root.rotate-cw();
                return EventResult.accept;
            }
            if (event.text == "z" || event.text == "Z") {
                root.cycle-view();
                return EventResult.accept;
            }
            if (event.text == "f" || event.text == "F") {
                root.toggle-fullscreen();
                return EventResult.accept;
            }
            if (event.text == "i" || event.text == "I") {
                root.toggle-info();
                return EventResult.accept;
            }
            return EventResult.reject;
        }
    }
}
